# Flask
SECRET_KEY=replace-with-a-long-random-value

# TMDB: use either a v4 read access token (preferred) or a v3 API key.
TMDB_API_TOKEN=
TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w500

# Release provider
MEDIA_RELEASE_PROVIDER=jackett
JACKETT_URL=http://127.0.0.1:9117
JACKETT_API_KEY=
JACKETT_MIN_SEEDERS=5
JACKETT_RESULT_LIMIT=50

# Notion. DATABASE_ID is accepted and its first data source is discovered.
# Set DATA_SOURCE_ID directly when the database contains multiple data sources.
NOTION_TOKEN=
NOTION_DATABASE_ID=
NOTION_DATA_SOURCE_ID=
NOTION_VERSION=2025-09-03

# Notion property mapping (change the values to match your existing database).
NOTION_PROP_TITLE=Title
NOTION_PROP_TMDB_ID=TMDB ID
NOTION_PROP_TYPE=Type
NOTION_PROP_YEAR=Year
NOTION_PROP_POSTER=Poster
NOTION_PROP_OVERVIEW=Overview
NOTION_PROP_MAGNET=Magnet
NOTION_PROP_RELEASE_TITLE=Release Title
NOTION_PROP_WATCHED=Watched
NOTION_PROP_DATE_WATCHED=Date Watched
NOTION_PROP_SEASON=Season
NOTION_PROP_EPISODE=Episode

# Playback: webtorrent or external.
MEDIA_PLAYER_MODE=webtorrent
WEBTORRENT_CDN_URL=https://cdn.jsdelivr.net/npm/webtorrent@3.0.16/dist/webtorrent.min.js
WEBTORRENT_SW_CDN_URL=https://cdn.jsdelivr.net/npm/webtorrent@3.0.16/dist/sw.min.js

# Example external adapter. ${magnet} is substituted server-side.
# MEDIA_PLAYER_MODE=external
# MEDIA_EXTERNAL_PLAYER_URL_TEMPLATE=stremio:///detail/stream?magnet=${magnet}

MEDIA_SEARCH_LIMIT=20
MEDIA_HTTP_TIMEOUT=20
